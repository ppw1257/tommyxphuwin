// Fisher-Yates shuffle
function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

let deck = shuffle(comments);
let pointer = 0;
let totalShown = 0;

function getNext() {
  if (pointer >= deck.length) {
    deck = shuffle(comments);
    pointer = 0;
  }
  return deck[pointer++];
}

function randomize() {
  const text = getNext();
  totalShown++;

  const el = document.getElementById('commentText');
  const counter = document.getElementById('counterDisplay');

  el.style.opacity = '0';
  el.style.transform = 'translateY(16px)';
  el.style.transition = 'none';

  setTimeout(() => {
    el.textContent = text;
    document.getElementById('hashtagText').style.display = 'block';
    el.style.transition = 'opacity 0.4s ease-out, transform 0.4s ease-out';
    el.style.opacity = '1';
    el.style.transform = 'translateY(0)';
    spawnConfetti();
    counter.textContent = 'Comment #' + totalShown + ' · ' + comments.length + ' in pool';
  }, 180);
}

function spawnConfetti() {
  const container = document.getElementById('confettiContainer');
  const colors = ['#c8102e', '#ffffff', '#001f5c', '#e4002b', '#f5c842'];
  for (let i = 0; i < 12; i++) {
    const p = document.createElement('div');
    p.className = 'confetti-piece';
    p.style.cssText =
      'left:' + (Math.random() * 100) + '%;' +
      'top:' + (Math.random() * 50) + '%;' +
      'background:' + colors[i % colors.length] + ';' +
      'border-radius:' + (Math.random() > 0.5 ? '50%' : '2px') + ';' +
      'animation-delay:' + (Math.random() * 0.4).toFixed(2) + 's';
    container.appendChild(p);
    setTimeout(function(el){ return function(){ el.remove(); }; }(p), 1600);
  }
}

// Element SDK (optional)
const defaultConfig = {
  main_title: 'Tommy Hilfiger\nSummer Getaway Pop-Up',
  ba_name: 'Phuwin',
  background_color: '#001233',
  surface_color: '#002366',
  text_color: '#ffffff',
  primary_action_color: '#c8102e',
  secondary_action_color: '#001f5c',
  font_family: 'Playfair Display',
  font_size: 19
};

function applyConfig(config) {
  var bg      = config.background_color     || defaultConfig.background_color;
  var surface = config.surface_color        || defaultConfig.surface_color;
  var text    = config.text_color           || defaultConfig.text_color;
  var primary = config.primary_action_color || defaultConfig.primary_action_color;
  var font    = config.font_family          || defaultConfig.font_family;
  var size    = config.font_size            || defaultConfig.font_size;
  var title   = config.main_title           || defaultConfig.main_title;
  var ba      = config.ba_name             || defaultConfig.ba_name;
  document.getElementById('app').style.background = bg;
  document.getElementById('commentBox').style.background = 'linear-gradient(135deg,' + surface + ',' + bg + ')';
  document.getElementById('mainTitle').style.color = text;
  document.getElementById('mainTitle').style.fontFamily = font + ', Playfair Display, serif';
  document.getElementById('mainTitle').innerHTML = title.replace(/\n/g, '<br>');
  document.getElementById('mainTitle').style.fontSize = (size * 1.6) + 'px';
  document.getElementById('baName').textContent = ba;
  document.getElementById('commentText').style.color = text;
  document.getElementById('commentText').style.fontSize = size + 'px';
  document.getElementById('randomBtn').style.background = 'linear-gradient(135deg,' + primary + ',' + primary + 'dd)';
  document.getElementById('subTitle').style.color = primary;
}

if (window.elementSdk) {
  window.elementSdk.init({
    defaultConfig: defaultConfig,
    onConfigChange: function(config) { applyConfig(config); },
    mapToCapabilities: function(config) {
      return {
        recolorables: [
          { get: function(){ return config.background_color     || defaultConfig.background_color;     }, set: function(v){ config.background_color     = v; window.elementSdk.setConfig({background_color:     v}); } },
          { get: function(){ return config.surface_color        || defaultConfig.surface_color;        }, set: function(v){ config.surface_color        = v; window.elementSdk.setConfig({surface_color:        v}); } },
          { get: function(){ return config.text_color           || defaultConfig.text_color;           }, set: function(v){ config.text_color           = v; window.elementSdk.setConfig({text_color:           v}); } },
          { get: function(){ return config.primary_action_color || defaultConfig.primary_action_color; }, set: function(v){ config.primary_action_color = v; window.elementSdk.setConfig({primary_action_color: v}); } },
          { get: function(){ return config.secondary_action_color || defaultConfig.secondary_action_color; }, set: function(v){ config.secondary_action_color = v; window.elementSdk.setConfig({secondary_action_color: v}); } }
        ],
        borderables: [],
        fontEditable:  { get: function(){ return config.font_family || defaultConfig.font_family; }, set: function(v){ config.font_family = v; window.elementSdk.setConfig({font_family: v}); } },
