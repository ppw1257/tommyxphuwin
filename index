function copyComment() {
  const commentText = document.getElementById('commentText').textContent;
  if (!commentText || commentText === 'Tap the button to get a comment') return;
  const hashtags = '\n\n#TommyHilfiger #TommyFamily @tommyhilfiger #phuwintang @phuwintang';
  const fullText = commentText + hashtags;

  function onSuccess() {
    const label = document.getElementById('copyLabel');
    const btn = document.getElementById('copyBtn');
    label.textContent = 'Copied!';
    btn.style.background = 'rgba(200,16,46,0.25)';
    btn.style.borderColor = 'rgba(200,16,46,0.5)';
    setTimeout(() => {
      label.textContent = 'Copy Comment';
      btn.style.background = 'rgba(255,255,255,0.08)';
      btn.style.borderColor = 'rgba(255,255,255,0.18)';
    }, 2000);
  }

  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(fullText).then(onSuccess).catch(() => fallbackCopy(fullText, onSuccess));
  } else {
    fallbackCopy(fullText, onSuccess);
  }
}

function fallbackCopy(text, onSuccess) {
  const ta = document.createElement('textarea');
  ta.value = text;
  ta.style.cssText = 'position:fixed;top:0;left:0;opacity:0;pointer-events:none';
  document.body.appendChild(ta);
  ta.focus();
  ta.select();
  try {
    document.execCommand('copy');
    onSuccess();
  } catch(e) {
    alert('Please long-press the comment text to copy manually.');
  }
  document.body.removeChild(ta);
}

